# Copy to backend/.env or repo root .env (team convention TBD in AGENTS.md)

# SQLite (run API/workers with cwd = backend/)
DATABASE_URL=sqlite:///./data/app.db

# Required for browser-use agents + Claude scoring + documents (when implemented)
ANTHROPIC_API_KEY=

# Optional: if you configure browser-use against OpenAI instead or in addition
OPENAI_API_KEY=

# Optional: higher GitHub API rate limits for metadata / intel helpers
GITHUB_TOKEN=

# Optional: require this header on mutating API routes (X-API-Key)
DEMO_API_KEY=

# Use fixture / safe paths instead of live automation when true
DEMO_MODE=false

# Electron renderer → FastAPI
APP_API_BASE_URL=http://127.0.0.1:8000

# Handshake / LinkedIn / other sessions — add as you implement adapters
# HANDSHAKE_SESSION=
# LINKEDIN_SESSION=
